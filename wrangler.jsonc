/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"name": "resume-site",
	"main": "src/app.py",
	"route": "brycebreedlove.com/*",
	"compatibility_date": "2026-02-12",
	"compatibility_flags": [
		"python_workers"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
  	},
	"observability": {
		"enabled": true
	}
}